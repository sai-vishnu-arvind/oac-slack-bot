# Slack (Socket Mode)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Vertex AI
VERTEX_PROJECT_ID=your-gcp-project
VERTEX_REGION=us-east5
VERTEX_MODEL=claude-sonnet-4-6

# Auth — local dev only (pod uses Workload Identity, leave blank)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Anthropic API / LiteLLM mode (alternative to Vertex AI)
# ANTHROPIC_BASE_URL=http://localhost:8080
# ANTHROPIC_API_KEY=sk-...

# Plugin scan directories (colon-separated, defaults shown)
# PLUGIN_DIRS=~/.agents/skills:~/claude-plugins/plugins

# Default plugin — every message routes here when no router match.
# DEFAULT_PLUGIN=engineering-intelligence:oncall-agent

# Session TTL in seconds (default: 1800 = 30 min)
# SESSION_TTL_SECS=1800

# DevRev integration
# DEVREV_TOKEN=eyJhbGciOi...

# ── Guardrails ──
# MAX_MESSAGE_LENGTH=10000
# RATE_LIMIT_PER_USER=20
# RATE_LIMIT_PER_CHANNEL=50
# ALLOWED_CHANNELS=C01ABC123,C02DEF456
# COST_BUDGET_PER_USER=100000
# ENABLE_PII_REDACTION=true
# ENABLE_INJECTION_DETECTION=true
